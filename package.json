{
  "name": "r-plus-clinical",
  "version": "1.5.0",
  "description": "R+ — Laboratoriazo + Notas de Evolución",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "prebuild:mac": "node scripts/fetch-python-mac.js",
    "prebuild:win": "node scripts/fetch-python.js",
    "build:win": "electron-builder --win"
  },
  "author": "Mauricio Salas",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.hospitaluniversitario.rplusclinical",
    "productName": "R+",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "icon": "build/AppIcon.icns",
    "mac": {
      "icon": "build/AppIcon.icns",
      "category": "public.app-category.medical",
      "extraResources": [
        { "from": "python-runtime/mac-arm64", "to": "python-runtime/mac-arm64" },
        { "from": "python-runtime/mac-x64",   "to": "python-runtime/mac-x64"   }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        { "from": "python-runtime/win-x64", "to": "python-runtime/win-x64" }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "mausalas99",
      "repo": "r-mas"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "generate_note.py",
      "generate_indicaciones.py",
      "template.docx",
      "template_indicaciones.docx",
      "public/**/*",
      "build/AppIcon.icns",
      "build/icon.ico"
    ],
    "asarUnpack": [
      "generate_note.py",
      "generate_indicaciones.py",
      "template.docx",
      "template_indicaciones.docx"
    ]
  }
}
