{
  "name": "r-plus",
  "version": "1.8.3.1",
  "description": "R+ — Laboratoriazo + Notas de Evolución",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "npm run prebuild:mac && electron-builder --mac",
    "build:mac:signed": "npm run build:mac",
    "build:mac:unsigned": "npm run prebuild:mac && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:mac:arm64-only": "npm run prebuild:mac && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64",
    "prebuild:mac": "node scripts/fetch-python-mac.js",
    "prebuild:win": "node scripts/fetch-python.js",
    "build:win": "electron-builder --win",
    "release:write-yml": "node scripts/write-release-yml.js",
    "release:write-yml:mac": "node scripts/write-release-yml.js --mac-only",
    "build": "electron-builder"
  },
  "author": "Mauricio Salas",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "chart.js": "^4.5.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.hospitaluniversitario.rplusclinical",
    "productName": "R+",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "icon": "AppIcon.icns",
    "mac": {
      "icon": "AppIcon.icns",
      "category": "public.app-category.medical",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extraResources": [
        {
          "from": "python-runtime/mac-arm64",
          "to": "python-runtime/mac-arm64"
        },
        {
          "from": "python-runtime/mac-x64",
          "to": "python-runtime/mac-x64"
        }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "python-runtime/win-x64",
          "to": "python-runtime/win-x64"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "mausalas99",
      "repo": "r-mas"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "generate_note.py",
      "generate_indicaciones.py",
      "template.docx",
      "template_indicaciones.docx",
      "public/**/*",
      "build/AppIcon.icns",
      "build/icon.ico"
    ],
    "asarUnpack": [
      "generate_note.py",
      "generate_indicaciones.py",
      "template.docx",
      "template_indicaciones.docx"
    ]
  }
}
